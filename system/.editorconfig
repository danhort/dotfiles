
# Brandography team root .editorconfig configuration
# Projects can also have a local .editorconfig to customize syntax

## Top editorconfig File
root = true

## Universal Settings
[*]
charset = utf-8
indent_style = space
## editorconfig-tools is unable to ignore longs strings or urls
max_line_length = null
trim_trailing_whitespace = true


## PHP
[*.{php,html,phtml}]
indent_size = 4

## JS/TS
[*.{js, ts}]
quote_type = single
indent_size = 2

## Makefile
[{Makefile,Makefile.*}]
indent_style = tab
indent_size = 4

## csv
[*.csv]
insert_final_newline = false

## Bash
[*.sh]
indent_size = 4
indent_type = tab

## XML
[*.xml]
indent_size = 4
